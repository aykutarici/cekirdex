# Public URL — tarayıcı tarafında kullanılır (her ortamda ayarlanmalı)
NEXT_PUBLIC_API_URL=http://localhost:8080

# Docker içinde Next.js → backend-nginx'e doğrudan erişir (performans için)
# Docker dışında (yerel geliştirme) aşağıdaki gibi set edin:
# API_INTERNAL_URL=http://localhost:8080
API_INTERNAL_URL=http://backend-nginx
